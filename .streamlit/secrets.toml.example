# Streamlit Secrets Configuration
# Copy this file to secrets.toml and add your actual API key

# GROQ API Configuration
GROQ_API_KEY = "your-groq-api-key-here"

# Instructions:
# 1. Get your API key from https://console.groq.com
# 2. For local development: Create .streamlit/secrets.toml with your key
# 3. For Streamlit Cloud: Add secrets in app settings (Manage app → Settings → Secrets)
